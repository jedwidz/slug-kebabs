---
// Minimal, unobtrusive share control.
// Uses the native Web Share API where available (mobile share sheet,
// Safari + Chromium desktop); falls back to copy-link-to-clipboard
// (e.g. Firefox desktop). No third-party scripts, no tracking.
---

<button class="share-btn" type="button" aria-label="Share this post">
	<svg
		class="share-ic"
		viewBox="0 0 24 24"
		width="15"
		height="15"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="18" cy="5" r="3"></circle>
		<circle cx="6" cy="12" r="3"></circle>
		<circle cx="18" cy="19" r="3"></circle>
		<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
		<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
	</svg>
	<span class="share-label">Share</span>
</button>

<style>
	.share-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font: inherit;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		background: transparent;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		padding: 0.3em 0.85em;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s;
	}
	.share-btn:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.share-ic {
		flex: none;
	}
</style>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.share-btn');
	buttons.forEach((btn) => {
		btn.addEventListener('click', async () => {
			const url = location.href;
			const title = document.title;
			const label = btn.querySelector('.share-label');
			try {
				if (navigator.share) {
					await navigator.share({ title, url });
					return;
				}
				await navigator.clipboard.writeText(url);
				if (label) {
					const prev = label.textContent;
					label.textContent = 'Link copied';
					setTimeout(() => {
						label.textContent = prev;
					}, 1500);
				}
			} catch {
				/* user cancelled the share sheet, or clipboard blocked — ignore */
			}
		});
	});
</script>
