---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — slug-kebabs" description="Jonathan Michael Edwards — career coder and full stack developer." />
	</head>
	<body>
		<Header />
		<main>
			<section class="profile">
				<img class="avatar" src="/profile.png" alt="Jonathan Michael Edwards" width="160" height="160" />
				<h1>Jonathan Michael Edwards</h1>
				<p class="handle">@jedwidz</p>
				<p class="bio">
					Career coder and full stack developer, creator of
					<a href="https://loggo-turtle.app/">LoGGo Turtle Graphics</a>.
				</p>
				<div class="links">
					<a href="https://x.com/jedwidz" target="_blank" rel="noopener" aria-label="Jedwidz on X">
						<svg viewBox="0 0 16 16" aria-hidden="true" width="26" height="26"><path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/></svg>
					</a>
					<a href="https://github.com/jedwidz" target="_blank" rel="noopener" aria-label="Jedwidz on GitHub">
						<svg viewBox="0 0 16 16" aria-hidden="true" width="26" height="26"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
					</a>
					<a href="https://jedwidz.hashnode.dev" target="_blank" rel="noopener" aria-label="Jedwidz on Hashnode">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24"><path fill="currentColor" d="M22.351 8.019l-6.37-6.37a5.63 5.63 0 0 0-7.962 0l-6.37 6.37a5.63 5.63 0 0 0 0 7.962l6.37 6.37a5.63 5.63 0 0 0 7.962 0l6.37-6.37a5.63 5.63 0 0 0 0-7.962zM12 15.713A3.713 3.713 0 1 1 12 8.287a3.713 3.713 0 0 1 0 7.426z"/></svg>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 3em 1em;
	}
	.profile {
		text-align: center;
	}
	.avatar {
		width: 160px;
		height: 160px;
		border-radius: 50%;
		object-fit: cover;
		background: #000;
		box-shadow: var(--box-shadow);
		margin-bottom: 0.6em;
	}
	.profile h1 {
		margin: 0.2em 0 0.1em;
	}
	.handle {
		margin: 0 0 1em;
		color: rgb(var(--gray));
	}
	.bio {
		max-width: 32em;
		margin: 0 auto 1.2em;
		color: rgb(var(--gray-dark));
	}
	.links {
		display: flex;
		justify-content: center;
		gap: 1em;
	}
	.links a {
		color: rgb(var(--gray));
	}
	.links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
