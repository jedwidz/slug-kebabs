---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>slug-kebabs</h1>
			<p><em>What's on the menu?</em></p>
			<p>
				Attempts at communication of questionable success &mdash; technical
				notes, things built, and the occasional shout into the void.
			</p>
			<p><a href="/blog/">Have a look &rarr;</a></p>
		</main>
		<Footer />
	</body>
</html>
